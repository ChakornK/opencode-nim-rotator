{
  "name": "opencode-nim-rotator",
  "version": "1.0.0",
  "description": "An OpenCode plugin for managing and rotating multiple NVIDIA NIM API keys",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "bin": {
    "opencode-nim-rotator": "./bin/opencode-nim-rotator.ts"
  },
  "scripts": {
    "build": "tsc",
    "tui": "bun run bin/opencode-nim-rotator.ts",
    "prepare": "npm run build",
    "postinstall": "node scripts/postinstall.js",
    "uninstall": "node scripts/uninstall.js",
    "format": "prettier -w ."
  },
  "keywords": [
    "opencode",
    "plugin",
    "nvidia",
    "nim",
    "api-key",
    "rotation"
  ],
  "author": "ChakornK",
  "license": "MIT",
  "files": [
    "dist",
    "bin",
    "scripts",
    "src"
  ],
  "dependencies": {
    "@opencode-ai/plugin": "^1.15.10",
    "@opentui/core": "^0.2.15"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "prettier": "^3.8.3",
    "typescript": "6.0.3"
  },
  "peerDependencies": {
    "bun": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "bun": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
