{
	"name": "@hallaxius/opencode-nim-rotator",
	"version": "0.2.5",
	"description": "An OpenCode plugin for managing and rotating multiple NVIDIA NIM API keys",
	"main": "dist/index.js",
	"types": "./dist/index.d.ts",
	"type": "module",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"require": "./dist/cjs/index.cjs",
			"types": "./dist/index.d.ts"
		},
		"./server": {
			"import": "./dist/server.js",
			"require": "./dist/cjs/server.cjs",
			"types": "./dist/server.d.ts"
		},
		"./tui": {
			"import": "./dist/tui-plugin.js",
			"require": "./dist/cjs/tui-plugin.cjs",
			"types": "./dist/tui-plugin.d.ts"
		}
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "npm run build:esm && npm run build:cjs",
		"build:esm": "tsc",
		"build:cjs": "npx rimraf dist/cjs && tsc -p tsconfig.cjs.json && node scripts/rename-cjs.cjs",
		"tui": "bun run src/bin.ts",
		"prepare": "bun run build",
		"uninstall": "node scripts/uninstall.js",
		"format": "prettier -w .",
		"patch": "npm version patch && bun publish",
		"minor": "npm version minor && bun publish",
		"major": "npm version major && bun publish"
	},
	"keywords": [
		"opencode",
		"plugin",
		"nvidia",
		"nim",
		"api-key",
		"rotation"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/hallaxius/opencode-nim-rotator.git"
	},
	"bugs": {
		"url": "https://github.com/hallaxius/opencode-nim-rotator/issues"
	},
	"homepage": "https://github.com/hallaxius/opencode-nim-rotator#readme",
	"author": "ChakornK",
	"license": "MIT",
	"files": [
		"dist",
		"scripts"
	],
	"dependencies": {
		"@opencode-ai/plugin": "^1.17.11",
		"@opentui/core": "^0.4.2"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.1",
		"@types/bun": "^1.3.14",
		"copyfiles": "^2.4.1",
		"cross-env": "^10.1.0",
		"prettier": "^3.8.4",
		"rimraf": "^6.1.3",
		"typescript": "6.0.3"
	},
	"peerDependencies": {
		"bun": ">=1.0.0"
	},
	"peerDependenciesMeta": {
		"bun": {
			"optional": true
		}
	},
	"engines": {
		"opencode": "^1.0.0",
		"node": ">=18.0.0"
	}
}
